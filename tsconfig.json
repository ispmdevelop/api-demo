{
  "ts-node": {
    "transpileOnly": true,
    "files": true
  },
  "typeRoots": ["node_modules/@types"],
  "include": ["src/**/*"],
  "exclude": [
    "./coverage",
    "./dist",
    "jest.config.js",
    "node_modules",
    "src/test-data",
    "src/**/*.spec.ts"
  ],
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "rootDir": "./src",
    "moduleResolution": "node",
    "checkJs": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "types": ["node", "express"]
}
